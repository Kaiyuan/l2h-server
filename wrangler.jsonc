{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "l2h-server",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "ADMIN_PATH": "dashboard"
  },
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.node"],
      "fallthrough": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
