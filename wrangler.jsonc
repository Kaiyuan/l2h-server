{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "l2h-server",
  "main": "dist/worker.mjs",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "node build-worker.mjs"
  },
  "vars": {
    "ADMIN_PATH": "dashboard"
  },
  "observability": {
    "enabled": true
  }
}
